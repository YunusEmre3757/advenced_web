GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
SPRING_BASE_URL=http://localhost:8080
GRAPH_PORT=8002

# Postgres checkpoint (varsayilan). Memory-only dev icin: memory
GRAPH_CHECKPOINT_MODE=postgres
GRAPH_DATABASE_URL=postgresql://seismic:seismic_dev_only@localhost:5432/seismic

# LangSmith tracing — https://smith.langchain.com adresinden API key al
# true yapinca tum grafiklerin adim adim calismasini LangSmith'te gorebilirsin
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=seismic-command
