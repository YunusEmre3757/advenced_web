# Groq AI Configuration
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Spring Boot Backend
SPRING_BASE_URL=http://localhost:8080

# LangGraph Service
GRAPH_PORT=8002
GRAPH_DATABASE_URL=postgresql://seismic:seismic_dev_only@localhost:5432/seismic
GRAPH_CHECKPOINT_MODE=postgres

# LangSmith Tracing (optional, for debugging and monitoring)
# Set to "true" to enable LangSmith tracing in LangGraph
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls_your_langsmith_key_here
LANGCHAIN_PROJECT=seismic-command

# OpenAI API (for CrewAI agents)
# Get your API key from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk_your_openai_key_here
